{
  "info": {
    "name": "Smart Health API",
    "description": "Smart Health Consulting REST API v1.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Login (Patient)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('token', pm.response.json().token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@health.test\",\n  \"password\": \"password\"\n}"
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "Get Appointments",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/appointments"
      }
    },
    {
      "name": "List Doctors",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/doctors"
      }
    },
    {
      "name": "Symptom Check",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"symptoms\": [\"skin rash\", \"itching\"]\n}"
        },
        "url": "{{base_url}}/symptom-check"
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@health.test\"\n}"
        },
        "url": "{{base_url}}/forgot-password"
      }
    },
    {
      "name": "Admin Stats",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/admin/stats"
      }
    },
    {
      "name": "Admin Audit Logs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/admin/audit-logs"
      }
    }
  ]
}
